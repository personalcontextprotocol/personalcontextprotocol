{
  "name": "@pcp/protocol",
  "version": "0.1.0",
  "description": "Personal Context Protocol v0.1 alpha schemas and types",
  "license": "MIT",
  "type": "module",
  "author": "PCP maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/gitxpress/pcp.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/gitxpress/pcp/tree/main/packages/protocol",
  "bugs": {
    "url": "https://github.com/gitxpress/pcp/issues"
  },
  "keywords": [
    "personal-context",
    "protocol",
    "json-rpc",
    "zod",
    "schema",
    "consent",
    "provenance"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:schema": "tsx src/generate-json-schema.ts"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
