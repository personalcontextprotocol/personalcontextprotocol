{
  "name": "@pcp/client",
  "version": "0.1.0",
  "description": "PCP v0.1 alpha TypeScript client",
  "license": "MIT",
  "type": "module",
  "author": "PCP maintainers (replace before publication)",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/pcp.git",
    "directory": "client"
  },
  "homepage": "https://github.com/YOUR_ORG/pcp/tree/main/client",
  "bugs": {
    "url": "https://github.com/YOUR_ORG/pcp/issues"
  },
  "keywords": [
    "personal-context",
    "protocol",
    "client",
    "json-rpc",
    "consent",
    "context-pack"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pcp-client": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pcp/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
