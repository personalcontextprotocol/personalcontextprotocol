{
  "name": "pcp",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Context Protocol v0.1 alpha open protocol proposal and reference implementation",
  "license": "MIT",
  "type": "module",
  "author": "PCP maintainers (replace before publication)",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/pcp.git"
  },
  "homepage": "https://github.com/YOUR_ORG/pcp#readme",
  "bugs": {
    "url": "https://github.com/YOUR_ORG/pcp/issues"
  },
  "keywords": [
    "personal-context",
    "protocol",
    "ai",
    "consent",
    "provenance",
    "auditability",
    "context-pack",
    "reference-implementation"
  ],
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @pcp/server dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "generate:schema": "pnpm --filter @pcp/protocol generate:schema",
    "check:schema": "node tools/check-generated-artifacts.mjs",
    "check:sdk-contracts": "node tools/verify-sdk-contracts.mjs",
    "seed": "pnpm --filter @pcp/server seed",
    "audit:logs": "pnpm --filter @pcp/server audit:logs",
    "demo": "pnpm --filter @pcp/demo-client demo"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
